# -----------------------------------------------------------------------------
# FLUXAR - CONFIGURAÇÕES DE AMBIENTE (FRONTEND)
# -----------------------------------------------------------------------------

# --- API & BACKEND ---
# URL base para as chamadas de API ao backend.
# Local: http://localhost:8000/api
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# --- FEATURE FLAGS & UI ---
# Habilita ou desabilita rastreamento/analytics (Opcional)
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Exibe o seletor de tema (Dark/Light) no Header.
# Útil para debug e desenvolvimento. Em produção, geralmente definido como 'false'.
# Valores aceitos: 'true' | 'false'
NEXT_PUBLIC_SHOW_THEME_TOGGLE=true

# Exibe a mensagem de wake-up do servidor em ambientes com limitações
NEXT_PUBLIC_SHOW_WAKEUP_MESSAGE=true